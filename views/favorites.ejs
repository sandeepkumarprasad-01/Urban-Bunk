<%- include('partials/header', { title: 'My Favorites - UrbanBUNK' }) %>

    <section class="favorites">
      <div class="container">
        <div class="heading-box">
          <h1>My Favorite Places</h1>
        </div>
        
        <% if (favorites.length === 0) { %>
          <div class="no-favorites-container">
            <div class="no-favorites-icon">
              <i class="fas fa-heart"></i>
            </div>
            <h2>No Favorites Yet</h2>
            <p>Start exploring and save your favorite properties for quick access!</p>
            <div class="no-favorites-actions">
              <a href="/" class="btn"><i class="fas fa-search"></i> Start Searching</a>
              <a href="/listings" class="btn btn-secondary">Browse All</a>
            </div>
          </div>
        <% } else { %>
          <div class="favorites-grid">
            <% favorites.forEach(favorite => { %>
              <div class="favorite-card reveal-on-scroll">
                <div class="favorite-image">
                  <% if (favorite.listing && favorite.listing.image && favorite.listing.image.url) { %>
                    <img src="<%= favorite.listing.image.url %>" alt="<%= favorite.listing.title %>">
                  <% } else if (favorite.listing && favorite.listing.image && typeof favorite.listing.image === 'string') { %>
                    <img src="<%= favorite.listing.image %>" alt="<%= favorite.listing.title %>">
                  <% } else { %>
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=60" alt="<%= favorite.listing ? favorite.listing.title : 'Property' %>">
                  <% } %>
                  <% if (favorite.listing) { %>
                    <div class="favorite-price">₹<%= favorite.listing.price ? favorite.listing.price.toLocaleString("en-IN") : 'N/A' %><span>/night</span></div>
                  <% } %>
                  <button class="remove-favorite" onclick="removeFavorite('<%= favorite._id %>')" title="Remove from favorites">
                    <i class="fas fa-heart-broken"></i>
                  </button>
                </div>
                <% if (favorite.listing) { %>
                <div class="favorite-content">
                  <h3><%= favorite.listing.title %></h3>
                  <p class="favorite-location">
                    <i class="fas fa-map-marker-alt"></i>
                    <%= favorite.listing.location %>, <%= favorite.listing.country %>
                  </p>
                  <p class="favorite-description" id="desc-<%= favorite._id %>"><%= favorite.listing.description %></p>
                  <button class="show-more-btn" onclick="toggleDescription('<%= favorite._id %>')" id="btn-<%= favorite._id %>">Show More</button>
                  <div class="favorite-details">
                    <span class="detail-item">
                      <i class="fas fa-users"></i>
                      Up to <%= favorite.listing.maxGuests %> guests
                    </span>
                    <span class="detail-item">
                      <i class="fas fa-check-circle"></i>
                      <%= favorite.listing.available ? 'Available' : 'Not Available' %>
                    </span>
                  </div>
                  <div class="favorite-actions">
                    <a href="/listings/<%= favorite.listing._id %>" class="btn">View Details</a>
                  </div>
                </div>
                <% } %>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>

    <script>
      async function removeFavorite(favoriteId) {
        if (confirm('Remove this from favorites?')) {
          try {
            const res = await fetch(`/favorites/${favoriteId}`, { method: 'DELETE' });
            if (res.ok) {
              const card = event.target.closest('.favorite-card');
              card.style.transition = 'all 0.3s ease';
              card.style.opacity = '0';
              card.style.transform = 'scale(0.8)';
              setTimeout(() => {
                card.remove();
                if (!document.querySelector('.favorite-card')) location.reload();
              }, 300);
            }
          } catch (e) { console.error(e); }
        }
      }

      function toggleDescription(id) {
        const desc = document.getElementById(`desc-${id}`);
        const btn = document.getElementById(`btn-${id}`);
        if (desc.classList.contains('expanded')) {
          desc.classList.remove('expanded');
          btn.textContent = 'Show More';
        } else {
          desc.classList.add('expanded');
          btn.textContent = 'Show Less';
        }
      }
    </script>

<%- include('partials/footer') %>