<%- include('../partials/header', { title: typeof title !== 'undefined' ? title : 'Login - UrbanBUNK' }) %>

    <section class="auth-container">
      <div class="auth-card">
        <div class="auth-header">
          <h2>Welcome Back</h2>
          <p>Sign in to your UrbanBUNK account</p>
        </div>

        <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
          <% errors.forEach(error => { %>
            <div class="alert alert-error">
              <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
          <% }); %>
        <% } %>

        <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
          <% success.forEach(message => { %>
            <div class="alert alert-success">
              <i class="fas fa-check-circle"></i> <%= message %>
            </div>
          <% }); %>
        <% } %>

        <form action="/login" method="POST" class="auth-form">
          <div class="form-group">
            <label for="email">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              placeholder="your@email.com"
              value="<%= typeof email !== 'undefined' ? email : '' %>"
            />
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input 
              type="password" 
              id="password" 
              name="password" 
              required 
              placeholder="Enter your password"
            />
          </div>

          <button type="submit" class="btn auth-btn">Sign In</button>
        </form>

        <div class="auth-footer">
          <p>Don't have an account? <a href="/register">Create one</a></p>
        </div>
      </div>
    </section>

<%- include('../partials/footer') %>
