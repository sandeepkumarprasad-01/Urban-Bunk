<%- include('../partials/header', { title: 'Create New Listing - UrbanBUNK' }) %>

    <div class="container" style="padding-top:12px; padding-bottom:80px;">
      <div class="heading-box">
        <h1>Create a New Listing</h1>
      </div>
      <form method="POST" action="/listings" class="listing-form">
        <div class="form-row">
          <div class="form-group">
            <label for="title">Property Title</label>
            <input id="title" name="listing[title]" placeholder="Enter your property title" type="text" required />
          </div>
          <div class="form-group">
            <label for="price">Price per Night (₹)</label>
            <input id="price" name="listing[price]" placeholder="Enter price" type="number" min="0" required />
          </div>
        </div>

        <div class="form-group" style="margin-bottom:20px;">
          <label for="description">Description</label>
          <textarea id="description" name="listing[description]" placeholder="Describe your property..." rows="4" required></textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="location">Location</label>
            <input id="location" name="listing[location]" placeholder="City, State" type="text" required />
          </div>
          <div class="form-group">
            <label for="country">Country</label>
            <input id="country" name="listing[country]" placeholder="Country" type="text" required />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="category">Category</label>
            <select id="category" name="listing[category]" required>
              <% categories.forEach(cat => { %>
                <option value="<%= cat %>"><%= cat %></option>
              <% }); %>
            </select>
          </div>
          <div class="form-group">
            <label for="propertyType">Property Type</label>
            <select id="propertyType" name="listing[propertyType]" required>
              <% propertyTypes.forEach(pt => { %>
                <option value="<%= pt %>"><%= pt %></option>
              <% }); %>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="maxGuests">Maximum Guests</label>
            <select id="maxGuests" name="listing[maxGuests]" required>
              <option value="1">1 Guest</option>
              <option value="2" selected>2 Guests</option>
              <option value="3">3 Guests</option>
              <option value="4">4 Guests</option>
              <option value="5">5 Guests</option>
              <option value="6">6+ Guests</option>
            </select>
          </div>
          <div class="form-group">
            <label for="available">Availability</label>
            <select id="available" name="listing[available]" required>
              <option value="true" selected>Available</option>
              <option value="false">Not Available</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="checkin">Available From</label>
            <input id="checkin" name="listing[checkin]" type="date" required />
          </div>
          <div class="form-group">
            <label for="checkout">Available Until</label>
            <input id="checkout" name="listing[checkout]" type="date" required />
          </div>
        </div>

        <div class="form-group" style="margin-bottom:20px;">
          <label>Amenities</label>
          <div class="amenities-checkboxes">
            <% 
              const allAmenities = ['WiFi', 'Air Conditioning', 'Smart TV', 'Kitchen', 'Free Parking', 'Pool Access', '24/7 Security', 'Pet Friendly', 'Gym', 'Washer', 'Dryer', 'Heating', 'Workspace', 'Balcony', 'Garden', 'BBQ', 'Hot Tub', 'Fireplace'];
            %>
            <% allAmenities.forEach(amenity => { %>
              <label class="amenity-checkbox">
                <input type="checkbox" name="listing[amenities]" value="<%= amenity %>" 
                  <%= ['WiFi', 'Air Conditioning'].includes(amenity) ? 'checked' : '' %> />
                <span><%= amenity %></span>
              </label>
            <% }); %>
          </div>
        </div>

        <div class="form-group" style="margin-bottom:0;">
          <label for="image">Image URL</label>
          <input id="image" name="listing[image]" placeholder="https://example.com/image.jpg" type="url" />
        </div>

        <div class="form-actions">
          <button type="submit" class="btn"><i class="fas fa-plus"></i> Create Listing</button>
          <a href="/listings" class="btn btn-secondary">Cancel</a>
        </div>
      </form>
    </div>

<%- include('../partials/footer') %>
