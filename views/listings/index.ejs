<%- include('../partials/header', { title: 'All Listings - UrbanBUNK' }) %>

    <section class="listings-section">
      <div class="container">
        <div class="heading-box">
          <h1>All Listings</h1>
        </div>

        <!-- Category Tabs + Sort -->
        <div class="listings-toolbar">
          <div class="category-tabs">
            <a href="/listings" class="cat-tab <%= !activeCategory ? 'active' : '' %>">All</a>
            <% categories.forEach(cat => { %>
              <a href="/listings?category=<%= cat %><%= activeSort !== 'newest' ? '&sort=' + activeSort : '' %>" 
                 class="cat-tab <%= activeCategory === cat ? 'active' : '' %>">
                <%= cat %>
              </a>
            <% }); %>
          </div>
          <div class="sort-dropdown">
            <select id="sortSelect" onchange="applySort(this.value)">
              <option value="newest" <%= activeSort === 'newest' ? 'selected' : '' %>>Newest First</option>
              <option value="price_low" <%= activeSort === 'price_low' ? 'selected' : '' %>>Price: Low to High</option>
              <option value="price_high" <%= activeSort === 'price_high' ? 'selected' : '' %>>Price: High to Low</option>
            </select>
          </div>
        </div>

        <% if (allListings.length === 0) { %>
          <div class="no-favorites-container">
            <div class="no-favorites-icon">
              <i class="fas fa-home"></i>
            </div>
            <h2>No Listings Found</h2>
            <p><%= activeCategory ? 'No ' + activeCategory + ' listings available. Try a different category!' : 'Be the first to add a property to our collection!' %></p>
            <div class="no-favorites-actions">
              <% if (activeCategory) { %>
                <a href="/listings" class="btn"><i class="fas fa-th"></i> View All</a>
              <% } %>
              <a href="/listings/new" class="btn btn-secondary"><i class="fas fa-plus"></i> Add Listing</a>
            </div>
          </div>
        <% } else { %>
          <div class="favorites-grid">
            <% allListings.forEach(listing => { %>
              <div class="favorite-card reveal-on-scroll">
                <div class="favorite-image">
                  <% if(listing.image && listing.image.url) { %>
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                  <% } else if(listing.image && typeof listing.image === 'string') { %>
                    <img src="<%= listing.image %>" alt="<%= listing.title %>">
                  <% } else { %>
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=60" alt="<%= listing.title %>">
                  <% } %>
                  <div class="favorite-price">₹<%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %><span>/night</span></div>
                  <i class="far fa-heart favorite-icon" data-listing-id="<%= listing._id %>"></i>
                  <% if (listing.category) { %>
                    <span class="card-category-tag"><%= listing.category %></span>
                  <% } %>
                </div>
                <div class="favorite-content">
                  <h3><%= listing.title %></h3>
                  <p class="favorite-location">
                    <i class="fas fa-map-marker-alt"></i>
                    <%= listing.location %>, <%= listing.country %>
                  </p>
                  <p class="favorite-description" id="desc-<%= listing._id %>"><%= listing.description || 'No description available' %></p>
                  <button class="show-more-btn" onclick="toggleDescription('<%= listing._id %>')" id="btn-<%= listing._id %>">Show More</button>
                  <div class="favorite-details">
                    <span class="detail-item">
                      <i class="fas fa-users"></i>
                      Up to <%= listing.maxGuests || 2 %> guests
                    </span>
                    <span class="detail-item">
                      <i class="fas fa-check-circle"></i>
                      <%= listing.available ? 'Available' : 'Not Available' %>
                    </span>
                    <% if (listing.propertyType) { %>
                      <span class="detail-item">
                        <i class="fas fa-building"></i>
                        <%= listing.propertyType %>
                      </span>
                    <% } %>
                  </div>
                  <div class="favorite-actions">
                    <a href="/listings/<%= listing._id %>" class="btn">View Details</a>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>

    <script>
      function toggleDescription(listingId) {
        const desc = document.getElementById(`desc-${listingId}`);
        const btn = document.getElementById(`btn-${listingId}`);
        if (desc.classList.contains('expanded')) {
          desc.classList.remove('expanded');
          btn.textContent = 'Show More';
        } else {
          desc.classList.add('expanded');
          btn.textContent = 'Show Less';
        }
      }

      function applySort(sortValue) {
        const url = new URL(window.location);
        url.searchParams.set('sort', sortValue);
        window.location = url.toString();
      }

      // Favorites
      document.querySelectorAll('.favorite-icon').forEach(icon => {
        icon.addEventListener('click', async function(e) {
          e.preventDefault();
          e.stopPropagation();
          const id = this.dataset.listingId;
          const isFav = this.classList.contains('favorited');
          try {
            if (isFav) {
              const res = await fetch(`/favorites/by-listing/${id}`, { method: 'DELETE' });
              if (res.ok) {
                this.classList.remove('favorited');
                this.classList.remove('fas');
                this.classList.add('far');
              }
            } else {
              const res = await fetch(`/favorites/${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
              if (res.status === 201) {
                this.classList.add('favorited');
                this.classList.remove('far');
                this.classList.add('fas');
              } else if (res.status === 401) {
                window.location.href = '/login';
              }
            }
          } catch(e) { console.error(e); }
        });
      });

      // Check favorites on load
      document.querySelectorAll('.favorite-icon').forEach(async icon => {
        const id = icon.dataset.listingId;
        try {
          const res = await fetch(`/favorites/check/${id}`);
          if (res.status === 401) return; // User not logged in, no favorites to check
          if (res.ok) { 
            const d = await res.json(); 
            if (d.isFavorited) {
              icon.classList.add('favorited');
              icon.classList.remove('far');
              icon.classList.add('fas');
            } 
          }
        } catch(e) {}
      });
    </script>

<%- include('../partials/footer') %>
