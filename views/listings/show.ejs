<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= listing.title %> - UrbanBUNK</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <header>
      <div class="logo">UrbanBUNK</div>
      <nav>
        <a href="/">Home</a>
        <a href="/listings">All Listings</a>
        <% if (currentUser) { %>
          <a href="/listings/new">Add Listing</a>
          <a href="/favorites">My Favorites</a>
          <a href="/logout">Logout</a>
          <span class="user-welcome">Welcome, <%= currentUser.username %></span>
        <% } else { %>
          <a href="/login">Login</a>
          <a href="/register">Register</a>
        <% } %>
      </nav>
    </header>
    <div class="container">
      <div class="show-container">
        <% if(listing.image && listing.image.url) { %>
          <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="show-image" />
        <% } else if(listing.image && typeof listing.image === 'string') { %>
          <img src="<%= listing.image %>" alt="<%= listing.title %>" class="show-image" />
        <% } else { %>
          <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=60" alt="<%= listing.title %>" class="show-image" />
        <% } %>
        <div class="show-content">
          <h1><%= listing.title %></h1>
          <p><strong>Location:</strong> <%= listing.location %>, <%= listing.country %></p>
          <p><strong>Price:</strong> ₹<%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %> / night</p>
          <p><strong>Description:</strong> <%= listing.description %></p>
          <% if(listing.maxGuests) { %>
            <p><strong>Max Guests:</strong> <%= listing.maxGuests %></p>
          <% } %>
          <% if(listing.available !== undefined) { %>
            <p><strong>Availability:</strong> <%= listing.available ? 'Available' : 'Not Available' %></p>
          <% } %>
          <div class="actions">
            <a href="/listings/<%= listing._id %>/edit" class="btn">Edit</a>
            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" style="display: inline;">
              <button type="submit" class="btn" onclick="return confirm('Are you sure you want to delete this listing?')">Delete</button>
            </form>
            <a href="/listings" class="btn">Back to Listings</a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
