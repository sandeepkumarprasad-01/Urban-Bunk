<%- include('../partials/header', { title: 'Search Results - UrbanBUNK' }) %>

    <section class="search-results">
      <div class="container">
        <div class="search-header">
          <h1>Search Results</h1>
          <% if (searchQuery.location || searchQuery.checkin || searchQuery.checkout || searchQuery.guests) { %>
            <div class="search-filters">
              <% if (searchQuery.location) { %>
                <span class="filter-tag">
                  <i class="fas fa-map-marker-alt"></i>
                  <%= searchQuery.location %>
                </span>
              <% } %>
              <% if (searchQuery.checkin) { %>
                <span class="filter-tag">
                  <i class="fas fa-calendar-check"></i>
                  Check-in: <%= searchQuery.checkin %>
                </span>
              <% } %>
              <% if (searchQuery.checkout) { %>
                <span class="filter-tag">
                  <i class="fas fa-calendar-times"></i>
                  Check-out: <%= searchQuery.checkout %>
                </span>
              <% } %>
              <% if (searchQuery.guests) { %>
                <span class="filter-tag">
                  <i class="fas fa-users"></i>
                  <%= searchQuery.guests %> Guests
                </span>
              <% } %>
            </div>
          <% } %>
          <div class="results-count">
            <% if (totalResults === 0) { %>
              <p class="no-results">No properties found matching your criteria.</p>
            <% } else { %>
              <p>Found <strong><%= totalResults %></strong> amazing properties</p>
            <% } %>
          </div>
        </div>

        <% if (searchResults.length > 0) { %>
          <div class="search-results-grid">
            <% searchResults.forEach(listing => { %>
              <div class="search-result-card reveal-on-scroll">
                <div class="result-image">
                  <% if (listing.image && listing.image.url) { %>
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                  <% } else { %>
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=60" alt="<%= listing.title %>">
                  <% } %>
                  <div class="result-price">₹<%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %><span>/night</span></div>
                  <i class="far fa-heart favorite-icon" data-listing-id="<%= listing._id %>"></i>
                </div>
                <div class="result-content">
                  <h3><%= listing.title %></h3>
                  <p class="result-location">
                    <i class="fas fa-map-marker-alt"></i>
                    <%= listing.location %>, <%= listing.country %>
                  </p>
                  <p class="result-description"><%= listing.description %></p>
                  <div class="result-details">
                    <span class="detail-item">
                      <i class="fas fa-users"></i>
                      Up to <%= listing.maxGuests %> guests
                    </span>
                    <span class="detail-item">
                      <i class="fas fa-check-circle"></i>
                      <%= listing.available ? 'Available' : 'Not Available' %>
                    </span>
                  </div>
                  <div class="result-actions">
                    <a href="/listings/<%= listing._id %>" class="btn">View Details</a>
                  </div>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <div class="no-results-container">
            <div class="no-results-icon">
              <i class="fas fa-search"></i>
            </div>
            <h2>No Properties Found</h2>
            <p>We couldn't find any properties matching your search criteria. Try adjusting your filters or search for a different location.</p>
            <div class="no-results-actions">
              <a href="/" class="btn"><i class="fas fa-home"></i> Back to Search</a>
              <a href="/listings" class="btn btn-secondary">View All Listings</a>
            </div>
          </div>
        <% } %>
      </div>
    </section>

    <script>
      // Favorites on search results
      document.querySelectorAll('.favorite-icon').forEach(icon => {
        icon.addEventListener('click', async function(e) {
          e.preventDefault();
          e.stopPropagation();
          const id = this.dataset.listingId;
          const isFav = this.classList.contains('favorited');
          try {
            if (isFav) {
              const res = await fetch(`/favorites/by-listing/${id}`, { method: 'DELETE' });
              if (res.ok) {
                this.classList.remove('favorited');
                this.classList.remove('fas');
                this.classList.add('far');
              }
            } else {
              const res = await fetch(`/favorites/${id}`, { method: 'POST', headers: { 'Content-Type': 'application/json' } });
              if (res.status === 201) {
                this.classList.add('favorited');
                this.classList.remove('far');
                this.classList.add('fas');
              } else if (res.status === 401) {
                window.location.href = '/login';
              }
            }
          } catch(e) { console.error(e); }
        });
      });

      document.querySelectorAll('.favorite-icon').forEach(async icon => {
        const id = icon.dataset.listingId;
        try {
          const res = await fetch(`/favorites/check/${id}`);
          if (res.status === 401) return; // User not logged in, no favorites to check
          if (res.ok) { 
            const d = await res.json(); 
            if (d.isFavorited) {
              icon.classList.add('favorited');
              icon.classList.remove('far');
              icon.classList.add('fas');
            } 
          }
        } catch(e) {}
      });
    </script>

<%- include('../partials/footer') %>
