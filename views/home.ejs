<%- include('partials/header', { title: 'Home - UrbanBUNK' }) %>

    <section class="hero">
      <div class="hero-content">
        <h1>Find your next urban adventure</h1>
        <p>Search deals on hotels, homes, and much more...</p>
        <div class="search-bar">
          <form class="search-form" action="/search" method="GET">
            <div class="search-input">
              <label for="location">Where are you going?</label>
              <input type="text" id="location" name="location" placeholder="Search destinations" />
            </div>
            <div class="search-input">
              <label for="checkin">Check-in</label>
              <input type="text" id="checkin" name="checkin" placeholder="Add date" />
            </div>
            <div class="search-input">
              <label for="checkout">Check-out</label>
              <input type="text" id="checkout" name="checkout" placeholder="Add date" />
            </div>
            <div class="search-input">
              <label for="guests">Guests</label>
              <select id="guests" name="guests">
                <option value="">Any</option>
                <option value="1">1 guest</option>
                <option value="2">2 guests</option>
                <option value="3">3 guests</option>
                <option value="4">4+ guests</option>
              </select>
            </div>
            <button type="submit" class="search-btn" aria-label="Search">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M21 21L16.5 16.5M19 11C19 15.4183 15.4183 19 11 19C6.58172 19 3 15.4183 3 11C3 6.58172 6.58172 3 11 3C15.4183 3 19 6.58172 19 11Z" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
      <div class="hero-image">
        <img src="https://images.unsplash.com/photo-1449824913935-59a10b8d2000?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" alt="Urban cityscape" />
      </div>
    </section>

    <!-- Category Filter Bar -->
    <section class="category-section">
      <div class="container">
        <div class="category-bar">
          <a href="/listings" class="category-item">
            <i class="fas fa-globe"></i>
            <span>All</span>
          </a>
          <% 
            const catIcons = {
              'Beach': 'fa-umbrella-beach', 'Mountain': 'fa-mountain', 'City': 'fa-city',
              'Countryside': 'fa-tree', 'Lake': 'fa-water', 'Desert': 'fa-sun',
              'Island': 'fa-sailboat', 'Cabin': 'fa-campground'
            };
          %>
          <% categories.forEach(cat => { %>
            <a href="/listings?category=<%= cat %>" class="category-item">
              <i class="fas <%= catIcons[cat] || 'fa-tag' %>"></i>
              <span><%= cat %></span>
            </a>
          <% }); %>
        </div>
      </div>
    </section>

    <section class="featured">
      <div class="container">
        <div class="section-header">
          <h2>Popular Destinations</h2>
          <p>Hand-picked properties loved by travelers around the world</p>
        </div>
        <% if (allListings.length === 0) { %>
          <div style="text-align:center;padding:40px 0;">
            <p style="color:var(--text-muted);font-size:16px;">No listings available yet. Be the first to add one!</p>
          </div>
        <% } else { %>
        <div class="destinations">
          <% for(let i = 0; i < allListings.length; i++) { %>
            <a href="/listings/<%= allListings[i]._id %>" class="destination-card" style="text-decoration:none;color:inherit;">
              <div class="card-image-wrapper">
                <% if(allListings[i].image && allListings[i].image.url) { %>
                  <img src="<%= allListings[i].image.url %>" alt="<%= allListings[i].title %>">
                <% } else if(allListings[i].image && typeof allListings[i].image === 'string') { %>
                  <img src="<%= allListings[i].image %>" alt="<%= allListings[i].title %>">
                <% } else { %>
                  <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=60" alt="<%= allListings[i].title %>">
                <% } %>
                <div class="card-overlay"></div>
                <div class="card-price-tag">₹<%= allListings[i].price ? allListings[i].price.toLocaleString("en-IN") : 'N/A' %><span>/night</span></div>
                <% if (allListings[i].category) { %>
                  <span class="card-category-tag"><%= allListings[i].category %></span>
                <% } %>
              </div>
              <div class="card-body">
                <h3><%= allListings[i].title %></h3>
                <p class="card-location"><i class="fas fa-map-marker-alt"></i> <%= allListings[i].location %>, <%= allListings[i].country %></p>
                <p class="card-desc"><%= allListings[i].description ? allListings[i].description.substring(0, 80) + '...' : '' %></p>
                <div class="card-footer-row">
                  <div class="card-tags">
                    <span class="detail-item"><i class="fas fa-users"></i> <%= allListings[i].maxGuests || 2 %></span>
                    <span class="detail-item"><i class="fas fa-check-circle"></i> <%= allListings[i].available !== false ? 'Available' : 'Booked' %></span>
                  </div>
                  <span class="view-details-link">View Details <i class="fas fa-arrow-right"></i></span>
                </div>
              </div>
            </a>
          <% } %>
        </div>
        <% } %>
        <div class="view-all">
          <a href="/listings" class="btn"><i class="fas fa-compass"></i> View All Listings</a>
        </div>
      </div>
    </section>

    <!-- Why UrbanBUNK Section -->
    <section class="trust-section">
      <div class="container">
        <div class="section-header">
          <h2>Why UrbanBUNK?</h2>
          <p>Trusted by thousands of travelers worldwide</p>
        </div>
        <div class="trust-grid">
          <div class="trust-card">
            <div class="trust-icon"><i class="fas fa-shield-alt"></i></div>
            <h3>Verified Properties</h3>
            <p>Every listing is verified by our team to ensure quality and safety standards</p>
          </div>
          <div class="trust-card">
            <div class="trust-icon"><i class="fas fa-headset"></i></div>
            <h3>24/7 Support</h3>
            <p>Our dedicated support team is available around the clock for any assistance</p>
          </div>
          <div class="trust-card">
            <div class="trust-icon"><i class="fas fa-lock"></i></div>
            <h3>Secure Booking</h3>
            <p>Your payments and personal information are protected with top-tier security</p>
          </div>
          <div class="trust-card">
            <div class="trust-icon"><i class="fas fa-undo"></i></div>
            <h3>Free Cancellation</h3>
            <p>Plans change — enjoy flexible cancellation on most properties</p>
          </div>
        </div>
      </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script>
      const today = new Date();
      const tomorrow = new Date(today);
      tomorrow.setDate(tomorrow.getDate() + 1);

      flatpickr("#checkin", {
        dateFormat: "Y-m-d",
        minDate: today,
        onChange: function(selectedDates) {
          if (selectedDates[0]) {
            checkoutPicker.set('minDate', new Date(selectedDates[0].getTime() + 86400000));
            if (!checkoutPicker.selectedDates[0] || checkoutPicker.selectedDates[0] <= selectedDates[0]) {
              checkoutPicker.setDate(new Date(selectedDates[0].getTime() + 86400000));
            }
          }
        }
      });

      const checkoutPicker = flatpickr("#checkout", {
        dateFormat: "Y-m-d",
        minDate: tomorrow
      });
    </script>

<%- include('partials/footer') %>