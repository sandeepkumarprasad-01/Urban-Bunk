<%- include('../partials/header', { title: 'My Bookings - UrbanBUNK' }) %>

    <section class="bookings-section">
      <div class="container">
        <div class="heading-box">
          <h1><i class="fas fa-calendar-alt"></i> My Bookings</h1>
        </div>

        <div class="bookings-tabs">
          <a href="/bookings?tab=upcoming" class="tab-btn <%= activeTab === 'upcoming' ? 'active' : '' %>">
            <i class="fas fa-clock"></i> Upcoming
          </a>
          <a href="/bookings?tab=past" class="tab-btn <%= activeTab === 'past' ? 'active' : '' %>">
            <i class="fas fa-history"></i> Past
          </a>
          <a href="/bookings?tab=cancelled" class="tab-btn <%= activeTab === 'cancelled' ? 'active' : '' %>">
            <i class="fas fa-times-circle"></i> Cancelled
          </a>
        </div>

        <% if (bookings.length === 0) { %>
          <div class="no-favorites-container">
            <div class="no-favorites-icon">
              <i class="fas fa-suitcase"></i>
            </div>
            <h2>No <%= activeTab %> bookings</h2>
            <p>
              <% if (activeTab === 'upcoming') { %>
                You don't have any upcoming trips. Start exploring amazing places!
              <% } else if (activeTab === 'past') { %>
                You haven't completed any trips yet.
              <% } else { %>
                No cancelled bookings found.
              <% } %>
            </p>
            <div class="no-favorites-actions">
              <a href="/listings" class="btn"><i class="fas fa-compass"></i> Explore Listings</a>
            </div>
          </div>
        <% } else { %>
          <div class="bookings-grid">
            <% bookings.forEach(booking => { %>
              <div class="booking-card-item reveal-on-scroll">
                <div class="booking-card-image">
                  <% if (booking.listing && booking.listing.image && booking.listing.image.url) { %>
                    <img src="<%= booking.listing.image.url %>" alt="<%= booking.listing.title %>">
                  <% } else { %>
                    <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=400&q=60" alt="Listing">
                  <% } %>
                  <div class="booking-status-badge status-<%= booking.status %>">
                    <%= booking.status.charAt(0).toUpperCase() + booking.status.slice(1) %>
                  </div>
                </div>
                <div class="booking-card-content">
                  <h3><%= booking.listing ? booking.listing.title : 'Listing Removed' %></h3>
                  <% if (booking.listing) { %>
                    <p class="booking-card-location">
                      <i class="fas fa-map-marker-alt"></i>
                      <%= booking.listing.location %>, <%= booking.listing.country %>
                    </p>
                  <% } %>
                  <div class="booking-card-dates">
                    <div class="booking-date-item">
                      <i class="fas fa-calendar-check"></i>
                      <span><%= booking.checkIn.toLocaleDateString('en-IN', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                    <i class="fas fa-arrow-right booking-arrow"></i>
                    <div class="booking-date-item">
                      <i class="fas fa-calendar-times"></i>
                      <span><%= booking.checkOut.toLocaleDateString('en-IN', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                    </div>
                  </div>
                  <div class="booking-card-meta">
                    <span><i class="fas fa-users"></i> <%= booking.guests %> guest<%= booking.guests > 1 ? 's' : '' %></span>
                    <span class="booking-card-price">₹<%= booking.totalPrice.toLocaleString('en-IN') %></span>
                  </div>
                  <% if (activeTab === 'upcoming' && (booking.status === 'pending' || booking.status === 'confirmed')) { %>
                    <div class="booking-card-actions">
                      <% if (booking.listing) { %>
                        <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm">View Listing</a>
                      <% } %>
                      <form action="/bookings/<%= booking._id %>/cancel" method="POST" style="display:inline;">
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Cancel this booking?')">
                          <i class="fas fa-times"></i> Cancel
                        </button>
                      </form>
                    </div>
                  <% } %>
                </div>
              </div>
            <% }); %>
          </div>
        <% } %>
      </div>
    </section>

<%- include('../partials/footer') %>
