# MongoDB Atlas Configuration
# Get your connection string from MongoDB Atlas: https://www.mongodb.com/atlas
# Click "Connect" → "Connect your application" → Copy the connection string

MONGO_URL=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/wanderlust?retryWrites=true&w=majority

# Replace:
# <username> - Your MongoDB Atlas username
# <password> - Your MongoDB Atlas password  
# cluster0.xxxxx - Your actual cluster name from Atlas
# wanderlust - Your database name (can keep as is)

# Session Secret (change this in production)
SESSION_SECRET=your-secret-key-change-this-in-production
